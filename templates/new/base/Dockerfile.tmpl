# Stage 1: Build Go toolchain from esrid/go fork
FROM golang:1.26-bookworm AS go-builder
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*
RUN git clone https://github.com/esrid/go.git /go-fork
WORKDIR /go-fork/src
ENV GOROOT_BOOTSTRAP=/usr/local/go
RUN ./make.bash

# Stage 2: Build application
FROM debian:bookworm-slim AS builder
COPY --from=go-builder /go-fork /usr/local/go
ENV PATH="/usr/local/go/bin:${PATH}"
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o [[.ProjectName]] .

# Stage 3: Minimal runtime
FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates tzdata && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /app/[[.ProjectName]] .
EXPOSE 8080
CMD ["./[[.ProjectName]]"]
