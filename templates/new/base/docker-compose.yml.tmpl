services:
  app:
    build: .
    ports:
      - "8080:8080"
    environment:
      - ENVIRONMENT=prod
      - SERVER_PORT=8080
[[- if .IsSQLite]]
      - DATABASE_URL=/data/[[.ProjectName]].db
    volumes:
      - app_data:/data
[[- else]]
      - DATABASE_URL=postgres://admin:password@db:5432/[[.ProjectName]]?sslmode=disable
    depends_on:
      db:
        condition: service_healthy

  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: password
      POSTGRES_DB: [[.ProjectName]]
    volumes:
      - pg_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U admin -d [[.ProjectName]]"]
      interval: 5s
      timeout: 5s
      retries: 5
[[- end]]

volumes:
[[- if .IsSQLite]]
  app_data:
[[- else]]
  pg_data:
[[- end]]
