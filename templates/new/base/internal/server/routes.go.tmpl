package server

import (
	"net/http"
	"time"

	api "[[.ModulePath]]/internal/adapters/http"
	"[[.ModulePath]]/internal/adapters/store"
	"[[.ModulePath]]/internal/core/ports"
[[- if .IsSSR]]
	"[[.ModulePath]]/web"
[[- end]]
	"github.com/go-chi/chi/v5"
	"github.com/go-chi/chi/v5/middleware"
	"github.com/go-chi/httprate"
)

type Handler struct {
	Store *store.Store
[[- if .Auth]]
	Auth *api.AuthHandler
[[- end]]
	// gogen:inject:handlers
}

func NewRouter(h *Handler, staticHandler http.Handler, sessionService ports.SessionService) http.Handler {
	r := chi.NewRouter()

	r.Use(httprate.LimitByIP(100, 1*time.Minute))
	r.Use(api.SecurityHeaders)
	r.Use(api.LimitRequestBody)
	r.Use(middleware.RequestID)
	r.Use(middleware.RealIP)
	r.Use(middleware.Logger)
	r.Use(middleware.Recoverer)
	r.Use(middleware.Timeout(60 * time.Second))
	r.Use(middleware.Compress(5))

	// CSRF protection
	csrf := http.NewCrossOriginProtection()
	r.Use(func(next http.Handler) http.Handler {
		return csrf.Handler(next)
	})

	// Static files
	if staticHandler != nil {
		r.Get("/static/*", func(w http.ResponseWriter, r *http.Request) {
			http.StripPrefix("/static/", staticHandler).ServeHTTP(w, r)
		})
	}

[[- if .Auth]]
	// Auth routes
	if h != nil && h.Auth != nil {
		r.Mount("/auth", h.Auth.Route())
	}
[[- end]]

	// Root
	r.Get("/", func(w http.ResponseWriter, r *http.Request) {
[[- if .Auth]]
		if sessionService != nil {
			if cookie, err := r.Cookie("session_token"); err == nil {
				if _, err := sessionService.Validate(r.Context(), cookie.Value); err == nil {
					http.Redirect(w, r, "/dashboard", http.StatusSeeOther)
					return
				}
			}
		}
[[- end]]
[[- if .IsSSR]]
		web.Render(w, "landing.html", map[string]any{
			"Title": "[[.ProjectName]]",
		})
[[- else]]
		w.Header().Set("Content-Type", "application/json")
		w.Write([]byte(`{"status":"ok"}`))
[[- end]]
	})

	// gogen:inject:routes

[[- if .Auth]]
	// Protected routes
	r.Group(func(r chi.Router) {
		r.Use(api.RequireAuth(sessionService))
		r.Use(api.NoCache)
		// gogen:inject:protected-routes
		r.Get("/dashboard", func(w http.ResponseWriter, r *http.Request) {
[[- if .IsSSR]]
			web.Render(w, "dashboard.html", map[string]any{"Title": "Dashboard"})
[[- else]]
			w.Header().Set("Content-Type", "application/json")
			w.Write([]byte(`{"status":"authenticated"}`))
[[- end]]
		})
	})
[[- end]]

	return r
}
