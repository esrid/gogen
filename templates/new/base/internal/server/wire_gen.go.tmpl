package server

import (
	"log/slog"
[[- if .Auth]]

	api "[[.ModulePath]]/internal/adapters/http"
	"[[.ModulePath]]/internal/adapters/external/email"
[[- end]]
	"[[.ModulePath]]/internal/adapters/store"
[[- if .Auth]]
	"[[.ModulePath]]/internal/core/ports"
	"[[.ModulePath]]/internal/core/services"
[[- end]]
)

type Handler struct {
	Store *store.Store
[[- if .Auth]]
	Auth           *api.AuthHandler
	SessionService ports.SessionService
[[- end]]
}

func WireHandlers(dbStore *store.Store, logger *slog.Logger) *Handler {
	h := &Handler{Store: dbStore}
[[- if .Auth]]

	emailProvider := email.NewNoopProvider()
	sessionSvc := services.NewSessionService(dbStore)
	h.SessionService = sessionSvc
	h.Auth = api.NewAuthHandler(services.NewAuthService(dbStore, emailProvider), dbStore, sessionSvc, logger)
[[- end]]
	return h
}
