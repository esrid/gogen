package api

import (
	"errors"
	"net/http"

	"[[.ModulePath]]/internal/domain"
	"[[.ModulePath]]/internal/utils"
)

func writeError(w http.ResponseWriter, err error) {
	switch {
	case errors.Is(err, domain.ErrNotFound):
		w.WriteHeader(http.StatusNotFound)
		utils.WriteJSON(w, map[string]string{"error": "not found"})
	case errors.Is(err, domain.ErrConflict):
		w.WriteHeader(http.StatusConflict)
		utils.WriteJSON(w, map[string]string{"error": "conflict"})
	case errors.Is(err, domain.ErrUnauthorized):
		w.WriteHeader(http.StatusUnauthorized)
		utils.WriteJSON(w, map[string]string{"error": "unauthorized"})
	case errors.Is(err, domain.ErrForbidden):
		w.WriteHeader(http.StatusForbidden)
		utils.WriteJSON(w, map[string]string{"error": "forbidden"})
	case errors.Is(err, domain.ErrInvalidInput):
		w.WriteHeader(http.StatusBadRequest)
		utils.WriteJSON(w, map[string]string{"error": err.Error()})
	default:
		w.WriteHeader(http.StatusInternalServerError)
		utils.WriteJSON(w, map[string]string{"error": "internal server error"})
	}
}
