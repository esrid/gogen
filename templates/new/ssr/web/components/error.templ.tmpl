package components

import "[[.ModulePath]]/web/layouts"

templ Error(message string) {
	@layouts.Layout("Error") {
		<div class="container mx-auto p-4 text-center">
			<h1 class="text-3xl font-bold text-error mb-4">Error</h1>
			<p class="text-lg">{ message }</p>
			<div class="mt-6">
				<a href="/" class="btn btn-primary">Go Home</a>
			</div>
		</div>
	}
}
