package api

import (
	"errors"
	"log/slog"
	"net/http"
[[- if .IsSSR]]
	"net/url"
[[- end]]

	"[[.ModulePath]]/internal/domain"
	"[[.ModulePath]]/internal/utils"
[[- if .IsSSR]]
	"[[.ModulePath]]/web"
	"[[.ModulePath]]/web/components/auth"
[[- end]]
	"github.com/go-chi/chi/v5"
)

type AuthHandler struct {
	userService    domain.UserService
	userStore      domain.UserStore
	sessionService domain.SessionService
	logger         *slog.Logger
}

func NewAuthHandler(us domain.UserService, st domain.UserStore, ss domain.SessionService, l *slog.Logger) *AuthHandler {
	return &AuthHandler{userService: us, userStore: st, sessionService: ss, logger: l}
}

func (h *AuthHandler) Register(r chi.Router) {
	r.Route("/auth", func(r chi.Router) {
[[- if .IsSSR]]
		r.Get("/login", h.showLogin)
[[- end]]
		r.Post("/login", h.handleLogin)
[[- if .IsSSR]]
		r.Get("/signup", h.showSignup)
[[- end]]
		r.Post("/signup", h.handleSignup)
[[- if .IsSSR]]
		r.Get("/forgot-password", h.showForgotPassword)
[[- end]]
		r.Post("/forgot-password", h.handleForgotPassword)
[[- if .IsSSR]]
		r.Get("/reset-password", h.showResetPassword)
[[- end]]
		r.Post("/reset-password", h.handleResetPassword)
		r.Post("/logout", h.handleLogout)

		r.Group(func(r chi.Router) {
			r.Use(RequireAuth(h.sessionService))
			r.Get("/settings", h.showSettings)
			r.Post("/settings/password", h.handleChangePassword)
			r.Post("/settings/delete", h.handleDeleteAccount)
		})
	})
}

func (h *AuthHandler) showLogin(w http.ResponseWriter, r *http.Request) {
[[- if .IsSSR]]
	web.Render(w, r, auth.Login(r.URL.Query().Get("error"), r.URL.Query().Get("msg")))
[[- else]]
	utils.WriteJSON(w, map[string]any{
		"Title": "Login",
		"Error": r.URL.Query().Get("error"),
		"Msg":   r.URL.Query().Get("msg"),
	})
[[- end]]
}

func (h *AuthHandler) showSignup(w http.ResponseWriter, r *http.Request) {
[[- if .IsSSR]]
	web.Render(w, r, auth.Signup(r.URL.Query().Get("error")))
[[- else]]
	utils.WriteJSON(w, map[string]any{
		"Title": "Sign Up",
		"Error": r.URL.Query().Get("error"),
	})
[[- end]]
}

func (h *AuthHandler) showForgotPassword(w http.ResponseWriter, r *http.Request) {
[[- if .IsSSR]]
	web.Render(w, r, auth.ForgotPassword(r.URL.Query().Get("error")))
[[- else]]
	utils.WriteJSON(w, map[string]any{
		"Title": "Forgot Password",
		"Error": r.URL.Query().Get("error"),
	})
[[- end]]
}

func (h *AuthHandler) showResetPassword(w http.ResponseWriter, r *http.Request) {
[[- if .IsSSR]]
	web.Render(w, r, auth.ResetPassword(r.URL.Query().Get("token"), r.URL.Query().Get("error")))
[[- else]]
	utils.WriteJSON(w, map[string]any{
		"Title": "Reset Password",
		"Token": r.URL.Query().Get("token"),
		"Error": r.URL.Query().Get("error"),
	})
[[- end]]
}

func (h *AuthHandler) showSettings(w http.ResponseWriter, r *http.Request) {
	userID, _ := r.Context().Value(domain.UserContextKey).(string)
	user, err := h.userStore.QueryUserByID(r.Context(), userID)
	if err != nil || user == nil {
		http.Redirect(w, r, "/auth/login", http.StatusSeeOther)
		return
	}
[[- if .IsSSR]]
	web.Render(w, r, auth.Settings(user, r.URL.Query().Get("error"), r.URL.Query().Get("msg")))
[[- else]]
	utils.WriteJSON(w, map[string]any{
		"Title": "Settings",
		"User":  user,
		"Error": r.URL.Query().Get("error"),
		"Msg":   r.URL.Query().Get("msg"),
	})
[[- end]]
}

func (h *AuthHandler) handleLogin(w http.ResponseWriter, r *http.Request) {
[[- if .IsSSR]]
	email := r.PostFormValue("email")
	password := r.PostFormValue("password")
	timezone := r.PostFormValue("timezone")
	remember := r.PostFormValue("remember") == "on"

	_, token, err := h.userService.Login(r.Context(), email, password, timezone)
	if err != nil {
		h.logger.Warn("login failed", "email", email, "error", err)
		http.Redirect(w, r, "/auth/login?error=invalid_credentials", http.StatusSeeOther)
		return
	}

	utils.SetSessionCookie(w, r, "session_token", token, remember)
	http.Redirect(w, r, "/dashboard", http.StatusSeeOther)
[[- else]]
	var input struct {
		Email    string `json:"email"`
		Password string `json:"password"`
		Timezone string `json:"timezone"`
	}
	if err := utils.DecodeJSON(r, &input); err != nil {
		utils.WriteJSONError(w, http.StatusBadRequest, err.Error())
		return
	}

	_, token, err := h.userService.Login(r.Context(), input.Email, input.Password, input.Timezone)
	if err != nil {
		h.logger.Warn("login failed", "email", input.Email, "error", err)
		utils.WriteJSONError(w, http.StatusUnauthorized, "invalid_credentials")
		return
	}

	utils.SetSessionCookie(w, r, "session_token", token, false)
	utils.WriteJSON(w, map[string]string{"token": token})
[[- end]]
}

func (h *AuthHandler) handleSignup(w http.ResponseWriter, r *http.Request) {
[[- if .IsSSR]]
	var input domain.NewUser
	input.Email = r.PostFormValue("email")
	input.Password = r.PostFormValue("password")
	input.Repeat = r.PostFormValue("confirmPassword")
	input.Timezone = r.PostFormValue("timezone")

	_, token, err := h.userService.Signup(r.Context(), &input)
	if err != nil {
		if errors.Is(err, domain.ErrInvalidInput) {
			http.Redirect(w, r, "/auth/signup?error="+url.QueryEscape(err.Error()), http.StatusSeeOther)
			return
		}
		h.logger.Error("signup failed", "error", err)
		http.Redirect(w, r, "/auth/signup?error=server_error", http.StatusSeeOther)
		return
	}

	utils.SetSessionCookie(w, r, "session_token", token, false)
	http.Redirect(w, r, "/dashboard", http.StatusSeeOther)
[[- else]]
	var input domain.NewUser
	if err := utils.DecodeJSON(r, &input); err != nil {
		utils.WriteJSONError(w, http.StatusBadRequest, err.Error())
		return
	}

	if err := utils.NewUserValidation(&input); err != nil {
		utils.WriteJSONError(w, http.StatusBadRequest, err.Error())
		return
	}

	_, token, err := h.userService.Signup(r.Context(), &input)
	if err != nil {
		h.logger.Error("signup failed", "error", err)
		utils.WriteJSONError(w, http.StatusInternalServerError, "server_error")
		return
	}

	utils.SetSessionCookie(w, r, "session_token", token, false)
	w.WriteHeader(http.StatusCreated)
	utils.WriteJSON(w, map[string]string{"token": token})
[[- end]]
}

func (h *AuthHandler) handleForgotPassword(w http.ResponseWriter, r *http.Request) {
[[- if .IsSSR]]
	_ = h.userService.ForgotPassword(r.Context(), r.PostFormValue("email"), utils.GetIPAddress(r))
	http.Redirect(w, r, "/auth/login?msg=reset_sent", http.StatusSeeOther)
[[- else]]
	var input struct {
		Email string `json:"email"`
	}
	if err := utils.DecodeJSON(r, &input); err != nil {
		utils.WriteJSONError(w, http.StatusBadRequest, err.Error())
		return
	}

	_ = h.userService.ForgotPassword(r.Context(), input.Email, utils.GetIPAddress(r))
	utils.WriteJSON(w, map[string]string{"message": "reset_sent"})
[[- end]]
}

func (h *AuthHandler) handleResetPassword(w http.ResponseWriter, r *http.Request) {
[[- if .IsSSR]]
	token := r.PostFormValue("token")
	if err := h.userService.ResetPassword(r.Context(), token, r.PostFormValue("new_password")); err != nil {
		http.Redirect(w, r, "/auth/reset-password?token="+token+"&error=failed", http.StatusSeeOther)
		return
	}
	http.Redirect(w, r, "/auth/login?msg=password_updated", http.StatusSeeOther)
[[- else]]
	var input struct {
		Token       string `json:"token"`
		NewPassword string `json:"new_password"`
	}
	if err := utils.DecodeJSON(r, &input); err != nil {
		utils.WriteJSONError(w, http.StatusBadRequest, err.Error())
		return
	}

	if err := h.userService.ResetPassword(r.Context(), input.Token, input.NewPassword); err != nil {
		utils.WriteJSONError(w, http.StatusBadRequest, "reset_failed")
		return
	}
	utils.WriteJSON(w, map[string]string{"message": "password_updated"})
[[- end]]
}

func (h *AuthHandler) handleChangePassword(w http.ResponseWriter, r *http.Request) {
	userID, _ := r.Context().Value(domain.UserContextKey).(string)
[[- if .IsSSR]]
	err := h.userService.ChangePassword(r.Context(), userID, r.PostFormValue("old_password"), r.PostFormValue("new_password"))
	if err != nil {
		http.Redirect(w, r, "/auth/settings?error="+url.QueryEscape(err.Error()), http.StatusSeeOther)
		return
	}
	http.Redirect(w, r, "/auth/settings?msg=password_changed", http.StatusSeeOther)
[[- else]]
	var input struct {
		OldPassword string `json:"old_password"`
		NewPassword string `json:"new_password"`
	}
	if err := utils.DecodeJSON(r, &input); err != nil {
		utils.WriteJSONError(w, http.StatusBadRequest, err.Error())
		return
	}

	if err := h.userService.ChangePassword(r.Context(), userID, input.OldPassword, input.NewPassword); err != nil {
		utils.WriteJSONError(w, http.StatusBadRequest, err.Error())
		return
	}
	utils.WriteJSON(w, map[string]string{"message": "password_changed"})
[[- end]]
}

func (h *AuthHandler) handleDeleteAccount(w http.ResponseWriter, r *http.Request) {
	userID, _ := r.Context().Value(domain.UserContextKey).(string)
	cookie, _ := r.Cookie("session_token")
[[- if .IsSSR]]
	if err := h.userService.DeleteAccount(r.Context(), userID); err != nil {
		http.Redirect(w, r, "/auth/settings?error=failed", http.StatusSeeOther)
		return
	}
	if cookie != nil {
		h.sessionService.Delete(r.Context(), cookie.Value)
	}
	utils.ClearSessionCookie(w, r, "session_token")
	http.Redirect(w, r, "/auth/login", http.StatusSeeOther)
[[- else]]
	if err := h.userService.DeleteAccount(r.Context(), userID); err != nil {
		utils.WriteJSONError(w, http.StatusInternalServerError, "delete_failed")
		return
	}
	if cookie != nil {
		h.sessionService.Delete(r.Context(), cookie.Value)
	}
	utils.ClearSessionCookie(w, r, "session_token")
	w.WriteHeader(http.StatusNoContent)
[[- end]]
}

func (h *AuthHandler) handleLogout(w http.ResponseWriter, r *http.Request) {
	if cookie, err := r.Cookie("session_token"); err == nil {
		h.sessionService.Delete(r.Context(), cookie.Value)
	}
	utils.ClearSessionCookie(w, r, "session_token")
[[- if .IsSSR]]
	http.Redirect(w, r, "/auth/login", http.StatusSeeOther)
[[- else]]
	utils.WriteJSON(w, map[string]string{"message": "logged_out"})
[[- end]]
}
