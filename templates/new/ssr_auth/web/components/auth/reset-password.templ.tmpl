package auth

import "[[.ModulePath]]/web/layouts"

templ ResetPassword(token, err string) {
	@layouts.Layout("Reset Password") {
		<div class="flex justify-center items-center py-12">
			<div class="card w-96 bg-base-100 shadow-xl">
				<div class="card-body">
					<h2 class="card-title justify-center mb-4">Reset Password</h2>

					if err != "" {
						<div class="alert alert-error mb-4">
							<span>{ err }</span>
						</div>
					}

					<form method="POST" action="/auth/reset-password">
						<input type="hidden" name="token" value={ token }/>
						<div class="form-control w-full">
							<label class="label">
								<span class="label-text">New Password</span>
							</label>
							<input type="password" name="new_password" class="input input-bordered w-full" required autocomplete="new-password"/>
						</div>
						<div class="card-actions mt-6">
							<button type="submit" class="btn btn-primary w-full">Reset Password</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	}
}
