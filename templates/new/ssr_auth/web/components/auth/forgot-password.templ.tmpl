package auth

import "[[.ModulePath]]/web/layouts"

templ ForgotPassword(err string) {
	@layouts.Layout("Forgot Password") {
		<div class="flex justify-center items-center py-12">
			<div class="card w-96 bg-base-100 shadow-xl">
				<div class="card-body">
					<h2 class="card-title justify-center mb-4">Forgot Password</h2>

					if err != "" {
						<div class="alert alert-error mb-4">
							<span>{ err }</span>
						</div>
					}

					<form method="POST" action="/auth/forgot-password">
						<div class="form-control w-full">
							<label class="label">
								<span class="label-text">Email</span>
							</label>
							<input type="email" name="email" class="input input-bordered w-full" required autocomplete="email"/>
						</div>
						<div class="card-actions mt-6">
							<button type="submit" class="btn btn-primary w-full">Send Reset Link</button>
						</div>
					</form>
					<div class="text-center mt-4">
						<a href="/auth/login" class="text-sm link link-hover">Back to Login</a>
					</div>
				</div>
			</div>
		</div>
	}
}
