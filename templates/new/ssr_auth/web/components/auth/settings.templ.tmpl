package auth

import (
	"[[.ModulePath]]/internal/domain"
	"[[.ModulePath]]/web/layouts"
)

templ Settings(user *domain.User, err, msg string) {
	@layouts.Layout("Settings") {
		<div class="container mx-auto p-4 max-w-2xl">
			<h1 class="text-3xl font-bold mb-8">Settings</h1>

			if err != "" {
				<div class="alert alert-error mb-6">
					<span>{ err }</span>
				</div>
			}
			if msg != "" {
				<div class="alert alert-info mb-6">
					<span>{ msg }</span>
				</div>
			}

			<div class="card bg-base-100 shadow-xl mb-8">
				<div class="card-body">
					<h2 class="card-title">Profile</h2>
					<p>Email: { user.Email }</p>
				</div>
			</div>

			<div class="card bg-base-100 shadow-xl">
				<div class="card-body">
					<h2 class="card-title mb-4">Change Password</h2>
					<form method="POST" action="/auth/settings/password">
						<div class="form-control w-full">
							<label class="label">
								<span class="label-text">Old Password</span>
							</label>
							<input type="password" name="old_password" class="input input-bordered w-full" required />
						</div>
						<div class="form-control w-full mt-4">
							<label class="label">
								<span class="label-text">New Password</span>
							</label>
							<input type="password" name="new_password" class="input input-bordered w-full" required />
						</div>
						<div class="card-actions mt-6">
							<button type="submit" class="btn btn-primary">Update Password</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	}
}
