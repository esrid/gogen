{{component "layout"}}
  {{fill "title"}}Edit [[.ModelName]]{{end}}
  {{fill "content"}}
  <div class="container">
    <h1>Edit [[.ModelName]]</h1>

    <form method="POST" action="[[.RoutePrefix]]/{{.[[$.ModelName]].ID}}">
[[- range .Fields]]
[[- if .IsRef]]
[[- else if eq .GoType "bool"]]
      <div class="field">
        <label>
          <input type="checkbox" name="[[.Name]]" value="on" {{if .[[$.ModelName]].[[.GoName]]}}checked{{end}} />
          [[.GoName]]
        </label>
      </div>
[[- else if eq .GoType "int"]]
      <div class="field">
        <label for="[[.Name]]">[[.GoName]]</label>
        <input type="number" id="[[.Name]]" name="[[.Name]]" value="{{.[[$.ModelName]].[[.GoName]]}}" />
      </div>
[[- else if eq .GoType "float64"]]
      <div class="field">
        <label for="[[.Name]]">[[.GoName]]</label>
        <input type="number" step="any" id="[[.Name]]" name="[[.Name]]" value="{{.[[$.ModelName]].[[.GoName]]}}" />
      </div>
[[- else if eq .GoType "time.Time"]]
      <div class="field">
        <label for="[[.Name]]">[[.GoName]]</label>
        <input type="datetime-local" id="[[.Name]]" name="[[.Name]]" value='{{.[[$.ModelName]].[[.GoName]].Format "2006-01-02T15:04"}}' />
      </div>
[[- else]]
      <div class="field">
        <label for="[[.Name]]">[[.GoName]]</label>
        <input type="text" id="[[.Name]]" name="[[.Name]]" value="{{.[[$.ModelName]].[[.GoName]]}}" />
      </div>
[[- end]]
[[- end]]
      <div class="actions">
        <button type="submit" class="btn">Update [[.ModelName]]</button>
        <a href="[[.RoutePrefix]]/{{.[[$.ModelName]].ID}}">Cancel</a>
      </div>
    </form>
  </div>
  {{end}}
{{end}}
