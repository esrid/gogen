{{component "layout"}}
  {{fill "title"}}[[.ModelNamePlural]]{{end}}
  {{fill "content"}}
  <div class="container">
    <div class="page-header">
      <h1>[[.ModelNamePlural]]</h1>
      <a href="[[.RoutePrefix]]/new" class="btn">New [[.ModelName]]</a>
    </div>

    <table>
      <thead>
        <tr>
[[- range .Fields]]
          <th>[[.GoName]]</th>
[[- end]]
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{range .[[.ModelNamePlural]]}}
        <tr>
[[- range .Fields]]
          <td>{{.[[.GoName]]}}</td>
[[- end]]
          <td>
            <a href="[[.RoutePrefix]]/{{.ID}}">View</a>
            <a href="[[.RoutePrefix]]/{{.ID}}/edit">Edit</a>
            <form method="POST" action="[[.RoutePrefix]]/{{.ID}}/delete" style="display:inline">
              <button type="submit" onclick="return confirm('Delete?')">Delete</button>
            </form>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{end}}
{{end}}
