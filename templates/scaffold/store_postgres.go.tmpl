package db

import (
	"context"
	"errors"

	"github.com/jackc/pgx/v5"

	"[[.ModulePath]]/internal/domain"
)

func (s *Store) Create[[.ModelName]](ctx context.Context, p domain.[[.ModelName]]) (domain.[[.ModelName]], error) {
	rows, _ := s.Pool.Query(ctx,
		`INSERT INTO [[.TableName]] ([[.InsertCols]]) VALUES ([[.PGInsert]]) RETURNING [[.SelectCols]]`,
		[[.InsertArgs]],
	)
	return pgx.CollectOneRow(rows, pgx.RowToStructByPos[domain.[[.ModelName]]])
}

func (s *Store) Get[[.ModelName]](ctx context.Context, id string) (*domain.[[.ModelName]], error) {
	rows, _ := s.Pool.Query(ctx,
		`SELECT [[.SelectCols]] FROM [[.TableName]] WHERE id = $1`,
		id,
	)
	p, err := pgx.CollectOneRow(rows, pgx.RowToStructByPos[domain.[[.ModelName]]])
	if errors.Is(err, pgx.ErrNoRows) {
		return nil, domain.ErrNotFound
	}
	return &p, err
}

func (s *Store) List[[.ModelName]]s(ctx context.Context) ([]domain.[[.ModelName]], error) {
	rows, _ := s.Pool.Query(ctx,
		`SELECT [[.SelectCols]] FROM [[.TableName]] ORDER BY created_at DESC`,
	)
	return pgx.CollectRows(rows, pgx.RowToStructByPos[domain.[[.ModelName]]])
}
[[range .Refs]]
func (s *Store) [[.StoreMethod]](ctx context.Context, [[.ParamName]] string) ([]domain.[[$.ModelName]], error) {
	rows, _ := s.Pool.Query(ctx,
		`SELECT [[$.SelectCols]] FROM [[$.TableName]] WHERE [[.FieldName]] = $1 ORDER BY created_at DESC`,
		[[.ParamName]],
	)
	return pgx.CollectRows(rows, pgx.RowToStructByPos[domain.[[$.ModelName]]])
}
[[end]]
func (s *Store) Update[[.ModelName]](ctx context.Context, p domain.[[.ModelName]]) error {
	_, err := s.Pool.Exec(ctx,
		`UPDATE [[.TableName]] SET [[.PGUpdate]], updated_at = NOW() WHERE id = [[.PGUpdateWhereN]]`,
		[[.UpdateArgs]],
	)
	return err
}

func (s *Store) Delete[[.ModelName]](ctx context.Context, id string) error {
	_, err := s.Pool.Exec(ctx, `DELETE FROM [[.TableName]] WHERE id = $1`, id)
	return err
}
