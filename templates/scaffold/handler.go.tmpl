package api

import (
	"log/slog"
	"net/http"

	"github.com/go-chi/chi/v5"

	"[[.ModulePath]]/internal/domain"
	"[[.ModulePath]]/internal/utils"
)

type [[.ModelName]][[if .IsBoth]]API[[end]]Handler struct {
	service domain.[[.ModelName]]Service
	logger  *slog.Logger
}

func New[[.ModelName]][[if .IsBoth]]API[[end]]Handler(service domain.[[.ModelName]]Service, logger *slog.Logger) *[[.ModelName]][[if .IsBoth]]API[[end]]Handler {
	return &[[.ModelName]][[if .IsBoth]]API[[end]]Handler{service: service, logger: logger}
}

func (h *[[.ModelName]][[if .IsBoth]]API[[end]]Handler) Register(r chi.Router) {
	r.Route("[[if .IsBoth]]/api[[end]][[.RoutePrefix]]", func(r chi.Router) {
		r.Get("/", h.list)
		r.Post("/", h.create)
		r.Get("/{id}", h.get)
		r.Put("/{id}", h.update)
		r.Delete("/{id}", h.delete)
[[- range .Refs]][[- if not .IsUserRef]]
		r.Get("/by-[[.URLSegment]]/{[[.ParamName]]}", h.listBy[[.RefModel]])
[[- end]][[- end]]
	})
}

func (h *[[.ModelName]][[if .IsBoth]]API[[end]]Handler) list(w http.ResponseWriter, r *http.Request) {
[[- if and .Protected .HasUserRef]]
	userID := domain.GetContextUser(r.Context())
	if userID == "" {
		writeError(w, domain.ErrUnauthorized)
		return
	}
	items, err := h.service.[[.UserRef.ServiceMethod]](r.Context(), userID)
[[- else if .Protected]]
	if domain.GetContextUser(r.Context()) == "" {
		writeError(w, domain.ErrUnauthorized)
		return
	}
	items, err := h.service.List(r.Context())
[[- else]]
	items, err := h.service.List(r.Context())
[[- end]]
	if err != nil {
		h.logger.Error("list [[.ModelNameLC]]s", "error", err)
		writeError(w, err)
		return
	}
	utils.WriteJSON(w, items)
}

func (h *[[.ModelName]][[if .IsBoth]]API[[end]]Handler) get(w http.ResponseWriter, r *http.Request) {
	id := chi.URLParam(r, "id")
	item, err := h.service.Get(r.Context(), id)
	if err != nil {
		h.logger.Error("get [[.ModelNameLC]]", "id", id, "error", err)
		writeError(w, err)
		return
	}
	utils.WriteJSON(w, item)
}

func (h *[[.ModelName]][[if .IsBoth]]API[[end]]Handler) create(w http.ResponseWriter, r *http.Request) {
[[- if .Protected]]
	userID := domain.GetContextUser(r.Context())
	if userID == "" {
		writeError(w, domain.ErrUnauthorized)
		return
	}
[[- end]]
	var m domain.[[.ModelName]]
	if err := utils.DecodeJSON(r, &m); err != nil {
		writeError(w, domain.ErrInvalidInput)
		return
	}
[[- if and .Protected .HasUserRef]]
	m.[[.UserRefGoName]] = userID
[[- end]]
	created, err := h.service.Create(r.Context(), m)
	if err != nil {
		h.logger.Error("create [[.ModelNameLC]]", "error", err)
		writeError(w, err)
		return
	}
	w.WriteHeader(http.StatusCreated)
	utils.WriteJSON(w, created)
}

func (h *[[.ModelName]][[if .IsBoth]]API[[end]]Handler) update(w http.ResponseWriter, r *http.Request) {
	id := chi.URLParam(r, "id")
	var m domain.[[.ModelName]]
	if err := utils.DecodeJSON(r, &m); err != nil {
		writeError(w, domain.ErrInvalidInput)
		return
	}
	m.ID = id
	if err := h.service.Update(r.Context(), m); err != nil {
		h.logger.Error("update [[.ModelNameLC]]", "id", id, "error", err)
		writeError(w, err)
		return
	}
	utils.WriteJSON(w, m)
}

func (h *[[.ModelName]][[if .IsBoth]]API[[end]]Handler) delete(w http.ResponseWriter, r *http.Request) {
	id := chi.URLParam(r, "id")
	if err := h.service.Delete(r.Context(), id); err != nil {
		h.logger.Error("delete [[.ModelNameLC]]", "id", id, "error", err)
		writeError(w, err)
		return
	}
	w.WriteHeader(http.StatusNoContent)
}
[[range .Refs]][[if not .IsUserRef]]
func (h *[[$.ModelName]][[if $.IsBoth]]API[[end]]Handler) listBy[[.RefModel]](w http.ResponseWriter, r *http.Request) {
	[[.ParamName]] := chi.URLParam(r, "[[.ParamName]]")
	items, err := h.service.[[.ServiceMethod]](r.Context(), [[.ParamName]])
	if err != nil {
		h.logger.Error("list [[$.ModelNameLC]]s by [[.RefModel]]", "[[.ParamName]]", [[.ParamName]], "error", err)
		writeError(w, err)
		return
	}
	utils.WriteJSON(w, items)
}
[[end]][[end]]
