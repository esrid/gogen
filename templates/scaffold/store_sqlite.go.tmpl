func (s *Store) Get[[.ModelName]](ctx context.Context, id string) (*domains.[[.ModelName]], error) {
	p := new(domains.[[.ModelName]])
	err := s.DB.QueryRowContext(ctx,
		`SELECT [[.SelectCols]] FROM [[.TableName]] WHERE id = ?`,
		id,
	).Scan([[.ScanArgs]])
	if errors.Is(err, sql.ErrNoRows) {
		return nil, domains.ErrNotFound
	}
	return p, err
}

func (s *Store) List[[.ModelName]]s(ctx context.Context) ([]domains.[[.ModelName]], error) {
	rows, err := s.DB.QueryContext(ctx,
		`SELECT [[.SelectCols]] FROM [[.TableName]] ORDER BY created_at DESC`,
	)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var results []domains.[[.ModelName]]
	for rows.Next() {
		var p domains.[[.ModelName]]
		if err := rows.Scan([[.ScanArgs]]); err != nil {
			return nil, err
		}
		results = append(results, p)
	}
	return results, rows.Err()
}
