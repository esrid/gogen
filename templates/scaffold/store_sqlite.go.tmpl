package db

import (
	"context"
	"database/sql"
	"errors"

	"[[.ModulePath]]/internal/domain"
)

func scan[[.ModelName]](r rowScanner) (domain.[[.ModelName]], error) {
	var p domain.[[.ModelName]]
[[- if .HasUserRef]]
	var [[.UserRefGoName]]Nullable sql.NullString
	err := r.Scan(
		&p.ID,
		[[- range .Fields]]
		[[- if .IsUserRef]]
		&[[$.UserRefGoName]]Nullable,
		[[- else]]
		&p.[[.GoName]],
		[[- end]]
		[[- end]]
		&p.CreatedAt, &p.UpdatedAt,
	)
	p.[[.UserRefGoName]] = [[.UserRefGoName]]Nullable.String
[[- else]]
	err := r.Scan([[.ScanArgs]])
[[- end]]
	return p, err
}

func collect[[.ModelName]]s(rows *sql.Rows) ([]domain.[[.ModelName]], error) {
	defer rows.Close()
	var out []domain.[[.ModelName]]
	for rows.Next() {
		p, err := scan[[.ModelName]](rows)
		if err != nil {
			return nil, err
		}
		out = append(out, p)
	}
	return out, rows.Err()
}

func (s *Store) Create[[.ModelName]](ctx context.Context, p domain.[[.ModelName]]) (domain.[[.ModelName]], error) {
	p.ID = generateID()
	return scan[[.ModelName]](s.DB.QueryRowContext(ctx,
		`INSERT INTO [[.TableName]] (id, [[.InsertCols]]) VALUES (?, [[.SQLiteInsert]]) RETURNING [[.SelectCols]]`,
		p.ID, [[.InsertArgs]],
	))
}

func (s *Store) Get[[.ModelName]](ctx context.Context, id string) (*domain.[[.ModelName]], error) {
	p, err := scan[[.ModelName]](s.DB.QueryRowContext(ctx,
		`SELECT [[.SelectCols]] FROM [[.TableName]] WHERE id = ?`,
		id,
	))
	if errors.Is(err, sql.ErrNoRows) {
		return nil, domain.ErrNotFound
	}
	return &p, err
}

func (s *Store) List[[.ModelName]]s(ctx context.Context) ([]domain.[[.ModelName]], error) {
	rows, err := s.DB.QueryContext(ctx,
		`SELECT [[.SelectCols]] FROM [[.TableName]] ORDER BY created_at DESC`,
	)
	if err != nil {
		return nil, err
	}
	return collect[[.ModelName]]s(rows)
}
[[range .Refs]]
func (s *Store) [[.StoreMethod]](ctx context.Context, [[.ParamName]] string) ([]domain.[[$.ModelName]], error) {
	rows, err := s.DB.QueryContext(ctx,
		`SELECT [[$.SelectCols]] FROM [[$.TableName]] WHERE [[.FieldName]] = ? ORDER BY created_at DESC`,
		[[.ParamName]],
	)
	if err != nil {
		return nil, err
	}
	return collect[[$.ModelName]]s(rows)
}
[[end]]
func (s *Store) Update[[.ModelName]](ctx context.Context, p domain.[[.ModelName]]) error {
	_, err := s.DB.ExecContext(ctx,
		`UPDATE [[.TableName]] SET [[.SQLiteUpdate]], updated_at = CURRENT_TIMESTAMP WHERE id = ?`,
		[[.UpdateArgs]],
	)
	return err
}

func (s *Store) Delete[[.ModelName]](ctx context.Context, id string) error {
	_, err := s.DB.ExecContext(ctx, `DELETE FROM [[.TableName]] WHERE id = ?`, id)
	return err
}
