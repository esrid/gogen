package [[.ModelNameLC]]

import (
	"[[.ModulePath]]/internal/domain"
	"[[.ModulePath]]/web/layouts"
)

templ Edit(item *domain.[[.ModelName]]) {
	@layouts.Layout("Edit [[.ModelName]]") {
		<div class="container mx-auto p-4">
			<div class="mb-6">
				<a href={ templ.URL("[[.RoutePrefix]]/" + item.ID) } class="text-sm hover:underline">← Back to [[.ModelName]]</a>
			</div>

			<div class="max-w-md mx-auto bg-base-100 shadow-xl p-6 rounded-lg">
				<h1 class="text-2xl font-bold mb-6">Edit [[.ModelName]]</h1>
				
				<form method="POST" action={ templ.URL("[[.RoutePrefix]]/" + item.ID) }>
					[[- range .Fields]]
					<div class="form-control w-full mb-4">
						<label class="label">
							<span class="label-text">[[.GoName]]</span>
						</label>
						<input type="text" name="[[.Name]]" value={ item.[[.GoName]] } class="input input-bordered w-full" required />
					</div>
					[[- end]]

					<div class="mt-6">
						<button type="submit" class="btn btn-primary w-full">Update [[.ModelName]]</button>
					</div>
				</form>
			</div>
		</div>
	}
}
