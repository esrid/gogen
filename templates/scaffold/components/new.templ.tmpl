package [[.ModelNameLC]]

import (
	"[[.ModulePath]]/web/layouts"
)

templ New() {
	@layouts.Layout("New [[.ModelName]]") {
		<div class="container mx-auto p-4">
			<div class="mb-6">
				<a href="[[.RoutePrefix]]" class="text-sm hover:underline">← Back to [[.ModelNamePlural]]</a>
			</div>

			<div class="max-w-md mx-auto bg-base-100 shadow-xl p-6 rounded-lg">
				<h1 class="text-2xl font-bold mb-6">New [[.ModelName]]</h1>
				
				<form method="POST" action="[[.RoutePrefix]]">
					[[- range .Fields]]
					<div class="form-control w-full mb-4">
						<label class="label">
							<span class="label-text">[[.GoName]]</span>
						</label>
						<input type="text" name="[[.Name]]" class="input input-bordered w-full" required />
					</div>
					[[- end]]

					<div class="mt-6">
						<button type="submit" class="btn btn-primary w-full">Create [[.ModelName]]</button>
					</div>
				</form>
			</div>
		</div>
	}
}
