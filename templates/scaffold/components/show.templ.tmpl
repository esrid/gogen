package [[.ModelNameLC]]

import (
	"[[.ModulePath]]/internal/domain"
	"[[.ModulePath]]/web/layouts"
)

templ Show(item *domain.[[.ModelName]]) {
	@layouts.Layout("[[.ModelName]] Details") {
		<div class="container mx-auto p-4">
			<div class="mb-6">
				<a href="[[.RoutePrefix]]" class="text-sm hover:underline">← Back to [[.ModelNamePlural]]</a>
			</div>
			
			<div class="bg-base-100 shadow-xl p-6 rounded-lg">
				<div class="flex justify-between items-center mb-6">
					<h1 class="text-2xl font-bold">[[.ModelName]] Details</h1>
					<div class="space-x-2">
						<a href={ templ.URL("[[.RoutePrefix]]/" + item.ID + "/edit") } class="btn btn-primary">Edit</a>
					</div>
				</div>

				<div class="space-y-4">
					[[- range .Fields]]
					<div>
						<label class="block text-sm font-medium opacity-70">[[.GoName]]</label>
						<p class="text-lg">{ item.[[.GoName]] }</p>
					</div>
					[[- end]]
				</div>
			</div>
		</div>
	}
}
