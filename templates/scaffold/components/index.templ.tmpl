package [[.ModelNameLC]]

import (
	"[[.ModulePath]]/internal/domain"
	"[[.ModulePath]]/web/layouts"
)

templ Index(items []domain.[[.ModelName]]) {
	@layouts.Layout("[[.ModelNamePlural]]") {
		<div class="container mx-auto p-4">
			<div class="flex justify-between items-center mb-6">
				<h1 class="text-2xl font-bold">[[.ModelNamePlural]]</h1>
				<a href="[[.RoutePrefix]]/new" class="btn btn-primary">New [[.ModelName]]</a>
			</div>

			<div class="overflow-x-auto">
				<table class="table w-full">
					<thead>
						<tr>
							[[- range .Fields]]
							<th>[[.GoName]]</th>
							[[- end]]
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						for _, item := range items {
							<tr>
								[[- range .Fields]]
								<td>{ item.[[.GoName]] }</td>
								[[- end]]
								<td>
									<div class="flex space-x-2">
										<a href={ templ.URL("[[.RoutePrefix]]/" + item.ID) } class="btn btn-sm">View</a>
										<a href={ templ.URL("[[.RoutePrefix]]/" + item.ID + "/edit") } class="btn btn-sm">Edit</a>
										<form method="POST" action={ templ.URL("[[.RoutePrefix]]/" + item.ID + "/delete") } onsubmit="return confirm('Are you sure?')">
											<button type="submit" class="btn btn-sm btn-error">Delete</button>
										</form>
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	}
}
